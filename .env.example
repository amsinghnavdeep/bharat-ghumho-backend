SECRET_KEY=your-secret-key-here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080
CLIENT_URL=http://localhost:4200

# Comma-separated list of allowed CORS origins.
# Defaults to common localhost ports if unset.
# CORS_ORIGINS=http://localhost:4200,http://localhost:3000

# Optional: OpenWeatherMap free tier API key
# Without this, /api/weather returns deterministic mock data.
OPENWEATHER_API_KEY=

# Optional: OpenTripMap free tier API key
# Without this, /api/places returns curated mock attractions.
OPENTRIPMAP_API_KEY=

# Optional: SQLite path. Defaults to <repo-root>/bharat_ghumho.db
# BG_DB_PATH=/var/data/bharat_ghumho.db
